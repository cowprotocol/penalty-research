# Strip notebook outputs/metadata on commit via nbstripout.
# The git filters themselves are wired up by `nbstripout --install`
# (run automatically in the devcontainer; see README for manual setup).
*.ipynb filter=nbstripout
*.ipynb diff=ipynb

# Keep the volatility notebook outputs so results render on GitHub.
short_term_volatility_estimation.ipynb -filter
penalty_cap_empirical_approach.ipynb -filter
