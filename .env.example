# Copy to .env (gitignored) and fill in. Loaded by fetch_penalties_data.py.

# Dune API key (the script executes saved query 7755542 via the Dune API).
DUNE_API_KEY=

# Read-only orderbook Postgres, one DSN per chain (CoW runs a DB per network).
# The script picks PENALTIES_DB_<CHAIN_UPPER> based on --chain.
PENALTIES_DB_POLYGON=postgresql://readonly:***@host:5432/orderbook
PENALTIES_DB_BNB=postgresql://readonly:***@host:5432/orderbook
