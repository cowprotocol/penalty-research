# Copy to .env (gitignored) and fill in. Loaded by fetch_penalties_data.py.

# Dune API key — the script executes saved query 7755542 via the Dune API.
DUNE_API_KEY=

# Read-only cow-analytics-db endpoint, as user:password@host:port
# (no scheme and no database name — the script selects the prod_<network>
# database based on --chain).
ANALYTICS_DB_URL=user:password@host:5432

PENALTIES_DATA_DIR="../data"
